datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String   @default("")
  picture   String   @default("")
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  submissions Submission[]
  events      Event[]

  @@map("users")
}

model Submission {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  companyName   String   @map("company_name")
  websiteUrl    String   @default("") @map("website_url")
  industry      String   @default("")
  stage         String   @default("")
  oneLiner      String   @default("") @map("one_liner")
  customers     String   @default("")
  endUser       String   @default("") @map("end_user")
  economicBuyer String   @default("") @map("economic_buyer")
  switchingTrigger String @default("") @map("switching_trigger")
  businessModel String   @default("") @map("business_model")
  traction      String   @default("")
  loiCount      String   @default("") @map("loi_count")
  pilotCount    String   @default("") @map("pilot_count")
  activeCustomerCount String @default("") @map("active_customer_count")
  paidCustomerCount String @default("") @map("paid_customer_count")
  monthlyRevenueValue String @default("") @map("monthly_revenue_value")
  growthRate    String   @default("") @map("growth_rate")
  deckUrl       String   @default("") @map("deck_url")
  demoUrl       String   @default("") @map("demo_url")
  customerProofUrl String @default("") @map("customer_proof_url")
  pilotDocsUrl  String   @default("") @map("pilot_docs_url")
  advantage     String   @default("")
  risk          String   @default("")
  primaryRiskCategory String @default("") @map("primary_risk_category")
  location      String   @default("")
  yearFounded   String   @default("") @map("year_founded")
  pricing       String   @default("")
  pricingModel  String   @default("") @map("pricing_model")
  startingPrice String   @default("") @map("starting_price")
  salesMotion   String   @default("") @map("sales_motion")
  typicalContractSize String @default("") @map("typical_contract_size")
  implementationComplexity String @default("") @map("implementation_complexity")
  timeToValue   String   @default("") @map("time_to_value")
  currentSubstitute String @default("") @map("current_substitute")
  revenue       String   @default("")
  funding       String   @default("")
  team          String   @default("")
  founderProblemFit String @default("") @map("founder_problem_fit")
  founderYearsInIndustry String @default("") @map("founder_years_in_industry")
  technicalFounder String @default("") @map("technical_founder")
  ask           String   @default("")
  competitors   String   @default("")
  extraContext           String   @default("") @map("extra_context")
  country               String   @default("")
  industryPriorityAreas String   @default("") @map("industry_priority_areas")
  keywords              String   @default("")
  hasCustomers          String   @default("") @map("has_customers")
  generatingRevenue     String   @default("") @map("generating_revenue")
  currentlyFundraising  String   @default("") @map("currently_fundraising")
  referralSource        String   @default("") @map("referral_source")
  status        String   @default("queued")
  adminNotes    String   @default("") @map("admin_notes")
  reportUrl     String   @default("") @map("report_url")
  score         Float?   @map("score")
  verdict       String   @default("") @map("verdict")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user           User             @relation(fields: [userId], references: [id])
  events         Event[]
  analysisResult AnalysisResult?
  outcomes       Outcome[]
  followUps      FollowUp[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("submissions")
}

model AnalysisResult {
  id             Int      @id @default(autoincrement())
  submissionId   Int      @unique @map("submission_id")
  analysisId     String   @default("") @map("analysis_id")

  // Final blended verdict
  compositeScore   Float  @map("composite_score")
  finalVerdict     String @map("final_verdict")
  finalConfidence  Float  @map("final_confidence")

  // Council dimension scores (reconciled)
  councilMarketTiming           Float? @map("council_market_timing")
  councilCompetitionLandscape   Float? @map("council_competition_landscape")
  councilBusinessModelViability Float? @map("council_business_model_viability")
  councilTeamExecutionSignals   Float? @map("council_team_execution_signals")
  councilRegulatoryNewsEnv      Float? @map("council_regulatory_news_env")
  councilSocialProofDemand      Float? @map("council_social_proof_demand")
  councilPatternMatch           Float? @map("council_pattern_match")
  councilCapitalEfficiency      Float? @map("council_capital_efficiency")
  councilScalabilityPotential   Float? @map("council_scalability_potential")
  councilExitPotential          Float? @map("council_exit_potential")
  councilOverall                Float? @map("council_overall")
  councilConfidence             Float? @map("council_confidence")

  // Swarm aggregated scores
  swarmMarketTiming           Float? @map("swarm_market_timing")
  swarmCompetitionLandscape   Float? @map("swarm_competition_landscape")
  swarmBusinessModelViability Float? @map("swarm_business_model_viability")
  swarmTeamExecutionSignals   Float? @map("swarm_team_execution_signals")
  swarmRegulatoryNewsEnv      Float? @map("swarm_regulatory_news_env")
  swarmSocialProofDemand      Float? @map("swarm_social_proof_demand")
  swarmPatternMatch           Float? @map("swarm_pattern_match")
  swarmCapitalEfficiency      Float? @map("swarm_capital_efficiency")
  swarmScalabilityPotential   Float? @map("swarm_scalability_potential")
  swarmExitPotential          Float? @map("swarm_exit_potential")
  swarmOverall                Float? @map("swarm_overall")
  swarmStdOverall             Float? @map("swarm_std_overall")
  swarmMedianOverall          Float? @map("swarm_median_overall")
  swarmPositivePct            Float? @map("swarm_positive_pct")
  swarmNegativePct            Float? @map("swarm_negative_pct")
  swarmAgentCount             Int?   @map("swarm_agent_count")

  // Risk panel
  riskPanelPenalty        Float? @map("risk_panel_penalty")
  riskHighSeverityCount   Int?   @map("risk_high_severity_count")
  riskMediumSeverityCount Int?   @map("risk_medium_severity_count")
  riskLowSeverityCount    Int?   @map("risk_low_severity_count")
  riskFindings            String @default("[]") @map("risk_findings")

  // OASIS simulation
  oasisTrajectory     String @default("") @map("oasis_trajectory")
  oasisStartSentiment Float? @map("oasis_start_sentiment")
  oasisFinalSentiment Float? @map("oasis_final_sentiment")
  oasisRounds         Int?   @map("oasis_rounds")

  // Research quality
  researchQualityScore       Float? @map("research_quality_score")
  researchCoverageScore      Float? @map("research_coverage_score")
  researchSourceQualityScore Float? @map("research_source_quality_score")
  researchFreshnessScore     Float? @map("research_freshness_score")

  // Metadata
  durationSeconds Float?   @map("duration_seconds")
  auditPath       String   @default("") @map("audit_path")
  createdAt       DateTime @default(now()) @map("created_at")

  submission Submission @relation(fields: [submissionId], references: [id])

  @@index([finalVerdict])
  @@index([compositeScore])
  @@index([createdAt])
  @@map("analysis_results")
}

model Outcome {
  id               Int      @id @default(autoincrement())
  submissionId     Int      @map("submission_id")
  recordedBy       String   @default("") @map("recorded_by")
  recordedByUserId Int?     @map("recorded_by_user_id")

  outcomeType      String   @map("outcome_type")
  details          String   @default("")
  verificationUrl  String   @default("") @map("verification_url")
  verified         Boolean  @default(false)

  roundType        String   @default("") @map("round_type")
  amountRaised     String   @default("") @map("amount_raised")
  revenueRange     String   @default("") @map("revenue_range")

  outcomeDate          String @default("") @map("outcome_date")
  monthsAfterAnalysis  Int?   @map("months_after_analysis")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  submission Submission @relation(fields: [submissionId], references: [id])

  @@index([submissionId])
  @@index([outcomeType])
  @@index([createdAt])
  @@map("outcomes")
}

model FollowUp {
  id           Int       @id @default(autoincrement())
  submissionId Int       @map("submission_id")
  dueAt        DateTime  @map("due_at")
  status       String    @default("pending")
  monthsAfter  Int       @map("months_after")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  submission Submission @relation(fields: [submissionId], references: [id])

  @@index([status, dueAt])
  @@index([submissionId])
  @@map("follow_ups")
}

model Event {
  id           Int      @id @default(autoincrement())
  event        String
  submissionId Int?     @map("submission_id")
  userId       Int?     @map("user_id")
  meta         String   @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  submission Submission? @relation(fields: [submissionId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("events")
}

model DailyUsage {
  id        Int      @id @default(autoincrement())
  day       String   @unique
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("daily_usage")
}

model PageView {
  id           Int      @id @default(autoincrement())
  path         String
  referrer     String?
  userAgent    String   @default("") @map("user_agent")
  ip           String   @default("")
  visitorId    String?  @map("visitor_id")
  sessionId    String?  @map("session_id")
  screenWidth  Int?     @map("screen_width")
  screenHeight Int?     @map("screen_height")
  language     String?
  city         String?
  region       String?
  country      String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([visitorId])
  @@map("page_views")
}
