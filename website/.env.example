# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# Mirai API
# Internal URL is used for server-to-server calls from Next.js to FastAPI.
MIRAI_API_INTERNAL_URL=http://127.0.0.1:5000
# Public URL is used for absolute founder/admin report links.
MIRAI_API_PUBLIC_URL=https://vclabs.org
# Optional explicit key for website -> swarm requests.
# Falls back to NEXTAUTH_SECRET when unset.
MIRAI_INTERNAL_API_KEY=

# Admin emails (comma-separated, lowercase)
MIRAI_ADMIN_EMAILS=your-email@gmail.com

# Database
DATABASE_URL=file:./data/mirai_portal.db
