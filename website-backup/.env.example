# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session signing key — generate: python -c "import secrets; print(secrets.token_hex(32))"
MIRAI_SESSION_SECRET=change-me-in-production

# Comma-separated admin emails (lowercase)
MIRAI_ADMIN_EMAILS=your-email@gmail.com

# Optional: base URL for production
# MIRAI_BASE_URL=https://mirai.example.com
